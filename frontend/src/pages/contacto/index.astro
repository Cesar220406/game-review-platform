---
import Layout from "../../layouts/Layout.astro";
import { getPaginaContacto } from "../../lib/api.js";
import ContactoHeader from "../../components/contacto/ContactoHeader.astro";
import ContactoFormulario from "../../components/contacto/ContactoFormulario.astro";
import ContactoInfo from "../../components/contacto/ContactoInfo.astro";
import ContactoFAQ from "../../components/contacto/ContactoFAQ.astro";

export const prerender = false;

const paginaContacto = await getPaginaContacto();
---

<Layout
  title={paginaContacto?.metaTitle ?? "Contacto | PixelCrit"}
  description={paginaContacto?.metaDescription ?? "¿Tienes alguna pregunta, sugerencia o quieres colaborar con PixelCrit? Ponte en contacto con nuestro equipo."}
>
  <section class="max-w-5xl mx-auto px-4 py-16">

    <ContactoHeader
      titulo={paginaContacto?.titulo ?? "Contacto"}
      descripcion={paginaContacto?.descripcion ?? "¿Tienes algo que contarnos? Rellena el formulario y te responderemos lo antes posible."}
    />

    <div class="grid md:grid-cols-2 gap-8 mt-12">

      <ContactoFormulario
        tituloFormulario={paginaContacto?.tituloFormulario ?? "Envíanos un mensaje"}
        labelNombre={paginaContacto?.labelNombre ?? "Nombre"}
        labelEmail={paginaContacto?.labelEmail ?? "Email"}
        labelAsunto={paginaContacto?.labelAsunto ?? "Asunto"}
        labelMensaje={paginaContacto?.labelMensaje ?? "Mensaje"}
        placeholderNombre={paginaContacto?.placeholderNombre ?? "Tu nombre"}
        placeholderEmail={paginaContacto?.placeholderEmail ?? "tu@email.com"}
        placeholderAsunto={paginaContacto?.placeholderAsunto ?? "Selecciona un asunto"}
        placeholderMensaje={paginaContacto?.placeholderMensaje ?? "Escribe tu mensaje aquí..."}
        textoBotonEnviar={paginaContacto?.textoBotonEnviar ?? "Enviar mensaje"}
      />

      <div class="flex flex-col gap-8">
        <ContactoInfo
          tituloInformacion={paginaContacto?.tituloInformacion ?? "Información"}
          emailContacto={paginaContacto?.emailContacto ?? "contacto@pixelcrit.es"}
          tiempoRespuesta={paginaContacto?.tiempoRespuesta ?? "24 - 48 horas"}
        />

        <ContactoFAQ
          tituloFAQ={paginaContacto?.tituloFAQ ?? "FAQ"}
        />
      </div>

    </div>

  </section>
</Layout>
