---
import Layout from "../../layouts/Layout.astro";
import { getArticulos } from "../../lib/api.js";

export const prerender = false;

const articulos = await getArticulos();
---

<Layout title="Blog | PixelCrit" description="Artículos y análisis sobre videojuegos">
  <section class="max-w-5xl mx-auto px-4 py-16">
    
    <h1 class="font-bungee text-4xl md:text-5xl text-text-primary uppercase mb-4">Blog</h1>
    <p class="text-text-secondary mb-12">Análisis, tendencias y cultura gamer.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articulos.map((articulo) => (
        <a href={`/blog/${articulo.slug}`} class="bg-dark-secondary border border-white/5 rounded-xl overflow-hidden hover:border-primary/30 transition group">
          
          <div class="p-6 flex flex-col gap-3">
            <p class="text-xs text-text-muted">
              {new Date(articulo.fechaPublicacion).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-bungee text-lg text-text-primary uppercase group-hover:text-primary transition leading-tight">
              {articulo.titulo}
            </h2>
            <p class="text-text-secondary text-sm leading-relaxed">{articulo.extracto}</p>
            <span class="text-primary text-sm font-medium mt-2">Leer artículo →</span>
          </div>

        </a>
      ))}
    </div>

  </section>
</Layout>