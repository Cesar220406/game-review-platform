---
import Layout from "../../layouts/Layout.astro";
import { getArticulos, getPaginaBlog } from "../../lib/api.js";
import { calcularTiempoLectura } from "../../lib/utils.js";
import BlogHeader from "../../components/blog/BlogHeader.astro";
import BlogDestacado from "../../components/blog/BlogDestacado.astro";
import BlogGrid from "../../components/blog/BlogGrid.astro";
import BlogPaginacion from "../../components/blog/BlogPaginacion.astro";

export const prerender = false;

const POR_PAGINA = 6;

const busquedaParam = Astro.url.searchParams.get("busqueda")?.trim() ?? "";
const pageParam = parseInt(Astro.url.searchParams.get("page") ?? "1", 10);
const paginaActual = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;

function normalizar(str: string) {
  return str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
}

const [todosArticulos, paginaBlog] = await Promise.all([getArticulos(), getPaginaBlog()]);

let articulosFiltrados = todosArticulos;
if (busquedaParam) {
  const q = normalizar(busquedaParam);
  articulosFiltrados = todosArticulos.filter((a: any) =>
    normalizar(a.titulo).includes(q) || normalizar(a.extracto ?? "").includes(q)
  );
}

const totalPaginas = Math.max(1, Math.ceil(articulosFiltrados.length / POR_PAGINA));
const paginaValida = Math.min(paginaActual, totalPaginas);

// En página 1 sin búsqueda mostramos el destacado aparte
const modoDestacado = paginaValida === 1 && !busquedaParam && articulosFiltrados.length > 0;
const articulosEnPagina = modoDestacado
  ? articulosFiltrados.slice(1, POR_PAGINA + 1)   // el slot 0 es el destacado
  : articulosFiltrados.slice((paginaValida - 1) * POR_PAGINA, paginaValida * POR_PAGINA);
const destacado = modoDestacado ? articulosFiltrados[0] : null;

function urlPagina(page: number) {
  const params = new URLSearchParams();
  if (busquedaParam) params.set("busqueda", busquedaParam);
  if (page > 1) params.set("page", String(page));
  const qs = params.toString();
  return `/blog${qs ? `?${qs}` : ""}`;
}

const rangoMin = Math.max(1, paginaValida - 2);
const rangoMax = Math.min(totalPaginas, paginaValida + 2);
const paginas = Array.from({ length: rangoMax - rangoMin + 1 }, (_, i) => rangoMin + i);
---

<Layout title={paginaBlog?.metaTitle ?? "Blog | PixelCrit"} description={paginaBlog?.metaDescription ?? "Artículos y análisis sobre videojuegos"}>
  <section class="max-w-5xl mx-auto px-4 py-16">

    <BlogHeader
      titulo={paginaBlog?.titulo ?? "Blog"}
      descripcion={paginaBlog?.descripcion ?? "Análisis, tendencias y cultura gamer."}
      placeholderBusqueda={paginaBlog?.placeholderBusqueda ?? "Buscar artículo..."}
      busquedaParam={busquedaParam}
      totalResultados={articulosFiltrados.length}
      textoResultados={paginaBlog?.textoResultados ?? "{count} resultados para"}
    />

    {destacado && (
      <BlogDestacado
        articulo={destacado}
        etiquetaDestacado={paginaBlog?.etiquetaDestacado ?? "Destacado"}
        textoLeerArticulo={paginaBlog?.textoLeerArticulo ?? "Leer artículo"}
        tiempoLectura={calcularTiempoLectura(destacado.contenido)}
      />
    )}

    {(!destacado || articulosEnPagina.length > 0) && (
      <BlogGrid
        articulos={articulosEnPagina}
        textoLeerArticulo={paginaBlog?.textoLeerArticulo ?? "Leer artículo"}
        textoSinResultados={paginaBlog?.textoSinResultados ?? "No hay artículos que coincidan con tu búsqueda."}
        textoVerTodos={paginaBlog?.textoVerTodos ?? "Ver todos los artículos"}
      />
    )}

    {totalPaginas > 1 && (
      <BlogPaginacion
        paginaActual={paginaValida}
        totalPaginas={totalPaginas}
        paginas={paginas}
        rangoMin={rangoMin}
        rangoMax={rangoMax}
        urlPagina={urlPagina}
        textoAnterior={paginaBlog?.textoAnterior ?? "Anterior"}
        textoSiguiente={paginaBlog?.textoSiguiente ?? "Siguiente"}
      />
    )}

  </section>
</Layout>
