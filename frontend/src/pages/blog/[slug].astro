---
import Layout from "../../layouts/Layout.astro";
import { getArticuloPorSlug } from "../../lib/api.js";
import { marked } from "marked";
import { calcularTiempoLectura } from "../../lib/utils.js";
import SeccionComentarios from "../../components/shared/SeccionComentarios.astro";

export const prerender = false;

const { slug } = Astro.params;
const articulo = await getArticuloPorSlug(slug);

if (!articulo) {
  return Astro.redirect("/404");
}

const {
  titulo,
  extracto,
  contenido,
  fechaPublicacion,
  autor,
  imagenDestacada,
  metaTitle,
  metaDescription,
} = articulo;

const contenidoSinH1 = contenido ? contenido.replace(/^#[^\n]*\n+/, '') : null;
const contenidoHtml = contenidoSinH1 ? marked(contenidoSinH1) : null;
const imagenUrl = imagenDestacada?.url
  ? imagenDestacada.url
  : null;
---

<Layout title={metaTitle ?? titulo} description={metaDescription ?? extracto}>
  <article class="max-w-4xl mx-auto px-4 py-16">

    <!-- VOLVER -->
    <div class="mb-10">
      <a href="/blog" class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
        </svg>
        Volver al blog
      </a>
    </div>

    <!-- CABECERA -->
    <header class="mb-10">
      <time class="text-primary text-sm font-semibold uppercase tracking-widest" datetime={fechaPublicacion}>
        {new Date(fechaPublicacion).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="font-bungee text-3xl md:text-5xl text-text-primary uppercase leading-tight mt-3 mb-3">
        {titulo}
      </h1>
      <p class="text-xs text-text-muted flex items-center gap-1 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
        </svg>
        {calcularTiempoLectura(contenido)} min de lectura
      </p>
      {extracto && (
        <p class="text-text-secondary text-lg md:text-xl leading-relaxed">{extracto}</p>
      )}
      {autor && (
        <p class="text-text-muted text-sm mt-4">
          Por <span class="text-text-secondary font-medium">{autor}</span>
        </p>
      )}
    </header>

    <!-- IMAGEN DESTACADA -->
    {imagenUrl && (
      <div class="rounded-2xl overflow-hidden border border-white/5 mb-12">
        <img
          src={imagenUrl}
          alt={titulo}
          class="w-full h-auto object-cover"
          width="900"
          height="500"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    )}

    <!-- CONTENIDO -->
    {contenidoHtml ? (
      <div
        class="prose prose-invert prose-lg max-w-none
               prose-headings:font-bungee prose-headings:uppercase prose-headings:text-text-primary
               prose-p:text-text-secondary prose-p:leading-relaxed
               prose-a:text-primary hover:prose-a:text-primary/80
               prose-strong:text-text-primary
               prose-blockquote:border-primary/40 prose-blockquote:text-text-muted
               prose-img:rounded-xl prose-img:border prose-img:border-white/5"
        set:html={contenidoHtml}
      />
    ) : (
      <div class="text-center py-12">
        <p class="text-text-muted">Este artículo aún no tiene contenido.</p>
      </div>
    )}

    <!-- COMENTARIOS -->
    <SeccionComentarios entidadTipo="articulo" entidadId={articulo.id} />

    <!-- VOLVER (PIE) -->
    <div class="mt-16 pt-8 border-t border-white/5">
      <a href="/blog" class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
        </svg>
        Volver al blog
      </a>
    </div>

  </article>
</Layout>
