---
import Layout from "../../layouts/Layout.astro";
import { getVideojuegoPorSlug, getPaginaVideojuegoDetalle } from "../../lib/api.js";
import { marked } from 'marked';
import SeccionComentarios from "../../components/shared/SeccionComentarios.astro";

export const prerender = false;

const { slug } = Astro.params;
const [videojuego, paginaDetalle] = await Promise.all([
  getVideojuegoPorSlug(slug),
  getPaginaVideojuegoDetalle(),
]);

if (!videojuego) {
  return Astro.redirect("/404");
}

const {
  titulo,
  descripcionCorta,
  descripcionCompleta,
  fechaLanzamiento,
  desarrolladora,
  puntuacion,
  imagenPrincipal,
  metaTitle,
  metaDescription,
  generos,
  plataformas,
} = videojuego;

const descripcionHtml = descripcionCompleta ? marked(descripcionCompleta) : null;
const imagenUrl = imagenPrincipal?.url ?? null;
const generosNombres = generos?.map((g :  any) => g.nombre) ?? [];
const plataformasNombres = plataformas?.map((p: any) => p.nombre) ?? [];
---

<Layout title={metaTitle ?? titulo} description={metaDescription ?? descripcionCorta}>
  <article class="max-w-5xl mx-auto px-4 py-16">

    <!-- CABECERA -->
    <div class="flex flex-col md:flex-row gap-10 mb-12">

      <!-- IMAGEN -->
      <div class="w-full md:w-2/5 rounded-xl overflow-hidden border border-white/10">
        {imagenUrl ? (
          <img
            src={imagenUrl}
            alt={titulo}
            class="w-full h-full object-cover"
            width="600"
            height="800"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <div class="w-full aspect-video bg-dark-secondary flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
            </svg>
          </div>
        )}
      </div>

      <!-- INFO -->
      <div class="flex-1 flex flex-col gap-5">

        <!-- GÉNEROS -->
        {generosNombres.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {generosNombres.map((g: string) => (
              <span class="text-xs bg-primary/10 text-primary border border-primary/20 rounded-full px-3 py-1">{g}</span>
            ))}
          </div>
        )}

        <h1 class="font-bungee text-4xl md:text-5xl text-text-primary uppercase leading-tight">
          {titulo}
        </h1>

        <p class="text-text-secondary text-lg leading-relaxed">{descripcionCorta}</p>

        <!-- PUNTUACIÓN -->
        {puntuacion != null && (
          <div class="flex items-center gap-3">
            <div class="bg-dark-secondary border border-white/10 rounded-xl px-5 py-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-secondary" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-3xl font-bold text-text-primary">{puntuacion}</span>
              <span class="text-text-muted">/100</span>
            </div>
          </div>
        )}

        <!-- DETALLES -->
        <div class="grid grid-cols-2 gap-4 mt-2">
          {desarrolladora && (
            <div class="bg-dark-secondary rounded-lg p-4 border border-white/5">
              <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{paginaDetalle?.etiquetaDesarrolladora ?? "Desarrolladora"}</p>
              <p class="text-text-primary font-medium">{desarrolladora}</p>
            </div>
          )}
          {fechaLanzamiento && (
            <div class="bg-dark-secondary rounded-lg p-4 border border-white/5">
              <p class="text-xs text-text-muted uppercase tracking-wider mb-1">{paginaDetalle?.etiquetaLanzamiento ?? "Lanzamiento"}</p>
              <p class="text-text-primary font-medium">
                {new Date(fechaLanzamiento).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </div>
          )}
        </div>

        <!-- PLATAFORMAS -->
        {plataformasNombres.length > 0 && (
          <div>
            <p class="text-xs text-text-muted uppercase tracking-wider mb-2">{paginaDetalle?.etiquetaDisponibleEn ?? "Disponible en"}</p>
            <div class="flex flex-wrap gap-2">
              {plataformasNombres.map((p: string) => (
                <span class="text-sm bg-dark-secondary border border-white/10 text-text-secondary rounded-full px-4 py-1.5">{p}</span>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>

    <!-- DESCRIPCIÓN COMPLETA -->
    {descripcionHtml && (
      <div class="bg-dark-secondary rounded-xl p-8 border border-white/5">
        <h2 class="font-bungee text-2xl text-text-primary uppercase mb-6">{paginaDetalle?.tituloSeccionAnalisis ?? "Análisis completo"}</h2>
        <div
          class="prose prose-invert prose-lg max-w-none
                 prose-headings:font-bungee prose-headings:uppercase prose-headings:text-text-primary
                 prose-p:text-text-secondary prose-p:leading-relaxed
                 prose-a:text-primary hover:prose-a:text-primary/80
                 prose-strong:text-text-primary
                 prose-blockquote:border-primary/40 prose-blockquote:text-text-muted
                 prose-img:rounded-xl prose-img:border prose-img:border-white/5"
          set:html={descripcionHtml}
        />
      </div>
    )}

    <!-- COMENTARIOS -->
    <SeccionComentarios entidadTipo="videojuego" entidadId={videojuego.id} />

    <!-- VOLVER -->
    <div class="mt-10">
      <a href="/videojuegos" class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
        </svg>
        {paginaDetalle?.textoVolver ?? "Volver a videojuegos"}
      </a>
    </div>

  </article>
</Layout>
