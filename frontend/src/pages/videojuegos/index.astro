---
import Layout from "../../layouts/Layout.astro";
import { getVideojuegos, getGeneros } from "../../lib/api.js";

const videojuegos = await getVideojuegos();
const generos = await getGeneros();
---

<Layout title="Videojuegos">
	<section class="max-w-7xl mx-auto px-4 py-10">
		<h1 class="text-4xl font-bold mb-6">Todos los videojuegos</h1>

		<!-- Buscador -->
		<input
			type="text"
			id="buscador"
			placeholder="Buscar..."
			class="px-4 py-2 rounded bg-dark-secondary text-white mb-4"
		/>

		<!-- Filtro géneros -->
		<select
			id="filtroGenero"
			class="px-4 py-2 rounded bg-dark-secondary text-white mb-6"
		>
			<option value="">Todos los géneros</option>
			{
				generos.map((g: any) => (
					<option value={g.slug}>{g.nombre}</option>
				))
			}
		</select>

		<!-- Lista -->
		<ul id="lista" class="space-y-3">
			{
				videojuegos.map((v :any) => (
					<li
						data-titulo={v.titulo}
						data-generos={v.generos.join(",")}
					>
						{v.titulo}
					</li>
				))
			}
		</ul>
	</section>

	<script>
		const buscador = document.getElementById("buscador") as HTMLInputElement;
		const filtroGenero = document.getElementById("filtroGenero") as HTMLSelectElement;
		const items = document.querySelectorAll("#lista li");

		function filtrar() {
			const texto = buscador.value.toLowerCase();
			const genero = filtroGenero.value;

			items.forEach((item) => {
				const el = item as HTMLElement;
				const titulo = (el.dataset.titulo || "").toLowerCase();
				const generos = el.dataset.generos || "";

				const coincideTexto = titulo.includes(texto);
				const coincideGenero = !genero || generos.split(",").includes(genero);

				el.style.display = coincideTexto && coincideGenero ? "" : "none";
			});
		}

		buscador.addEventListener("input", filtrar);
		filtroGenero.addEventListener("change", filtrar);
	</script>
</Layout>
