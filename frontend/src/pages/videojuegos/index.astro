---
import Layout from "../../layouts/Layout.astro";
import { getVideojuegos, getGeneros, getPlatforms, getPaginaVideojuegos } from "../../lib/api.js";
import VideojuegosHeader from "../../components/videojuegos/VideojuegosHeader.astro";
import VideojuegosFiltros from "../../components/videojuegos/VideojuegosFiltros.astro";
import VideojuegosGrid from "../../components/videojuegos/VideojuegosGrid.astro";
import VideojuegosPaginacion from "../../components/videojuegos/VideojuegosPaginacion.astro";

export const prerender = false;

type Genero = { id: number; nombre: string; slug: string };
type Plataforma = { id: number; nombre: string; slug: string };
type Videojuego = {
  id: number;
  titulo: string;
  slug: string;
  descripcionCorta?: string;
  puntuacion?: number;
  imagen?: string;
  generos: Genero[];
};

const POR_PAGINA = 9;

const generoParam = Astro.url.searchParams.get("genero");
const plataformaParam = Astro.url.searchParams.get("plataforma");
const busquedaParam = Astro.url.searchParams.get("busqueda")?.trim() ?? "";
const pageParam = parseInt(Astro.url.searchParams.get("page") ?? "1", 10);
const paginaActual = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;

function normalizar(str: string) {
  return str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
}

const [todosVideojuegos, generos, plataformas, paginaVideojuegos] = await Promise.all([
  getVideojuegos() as Promise<Videojuego[]>,
  getGeneros() as Promise<Genero[]>,
  getPlatforms() as Promise<Plataforma[]>,
  getPaginaVideojuegos(),
]);

let videojuegosFiltrados = todosVideojuegos;

if (generoParam) {
  videojuegosFiltrados = videojuegosFiltrados.filter((v) =>
    v.generos.some((g) => g.slug === generoParam)
  );
}

if (busquedaParam) {
  const q = normalizar(busquedaParam);
  videojuegosFiltrados = videojuegosFiltrados.filter((v) =>
    normalizar(v.titulo).includes(q)
  );
}

const totalPaginas = Math.max(1, Math.ceil(videojuegosFiltrados.length / POR_PAGINA));
const paginaValida = Math.min(paginaActual, totalPaginas);
const inicio = (paginaValida - 1) * POR_PAGINA;
const videojuegos = videojuegosFiltrados.slice(inicio, inicio + POR_PAGINA);

function urlPagina(page: number) {
  const params = new URLSearchParams();
  if (generoParam) params.set("genero", generoParam);
  if (plataformaParam) params.set("plataforma", plataformaParam);
  if (busquedaParam) params.set("busqueda", busquedaParam);
  if (page > 1) params.set("page", String(page));
  const qs = params.toString();
  return `/videojuegos${qs ? `?${qs}` : ""}`;
}

const rangoMin = Math.max(1, paginaValida - 2);
const rangoMax = Math.min(totalPaginas, paginaValida + 2);
const paginas = Array.from({ length: rangoMax - rangoMin + 1 }, (_, i) => rangoMin + i);

const generoActivo = generoParam ? generos.find((g) => g.slug === generoParam) : null;
const plataformaActiva = plataformaParam ? plataformas.find((p) => p.slug === plataformaParam) : null;

const filtroActivo = generoActivo?.nombre || plataformaActiva?.nombre || null;
const tituloPagina = paginaVideojuegos?.titulo ?? "Videojuegos";
const tituloSEO = filtroActivo
  ? `${tituloPagina} de ${filtroActivo} | PixelCrit`
  : (paginaVideojuegos?.metaTitle ?? "Videojuegos | PixelCrit");
const descripcionSEO = filtroActivo
  ? `Reseñas y análisis de videojuegos de ${filtroActivo} en PixelCrit.`
  : (paginaVideojuegos?.metaDescription ?? "Todas las reseñas de videojuegos en PixelCrit.");
---

<Layout title={tituloSEO} description={descripcionSEO}>
  <section class="max-w-7xl mx-auto px-4 py-16">

    <VideojuegosHeader
      titulo={filtroActivo ? `${tituloPagina} de ${filtroActivo}` : tituloPagina}
      descripcion={paginaVideojuegos?.descripcion ?? "Todas nuestras reseñas y análisis."}
      placeholderBusqueda={paginaVideojuegos?.placeholderBusqueda ?? "Buscar videojuego..."}
      busquedaParam={busquedaParam}
      totalResultados={videojuegosFiltrados.length}
      filtroActivo={filtroActivo}
      generoParam={generoParam}
    />

    <VideojuegosFiltros
      generos={generos}
      generoActivo={generoParam}
      busquedaParam={busquedaParam}
      textoTodos={paginaVideojuegos?.textoTodos ?? "Todos"}
    />

    <VideojuegosGrid
      videojuegos={videojuegos}
      textoSinResultados={paginaVideojuegos?.textoSinResultados ?? "No hay videojuegos que coincidan con tu búsqueda."}
      textoVerTodos={paginaVideojuegos?.textoVerTodos ?? "Ver todos los videojuegos"}
    />

    {totalPaginas > 1 && (
      <VideojuegosPaginacion
        paginaActual={paginaValida}
        totalPaginas={totalPaginas}
        paginas={paginas}
        rangoMin={rangoMin}
        rangoMax={rangoMax}
        urlPagina={urlPagina}
        textoAnterior={paginaVideojuegos?.textoAnterior ?? "Anterior"}
        textoSiguiente={paginaVideojuegos?.textoSiguiente ?? "Siguiente"}
      />
    )}

  </section>
</Layout>
