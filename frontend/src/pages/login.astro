---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Iniciar sesión — PixelCrit" description="Accede a tu cuenta de PixelCrit para comentar y opinar sobre videojuegos.">
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">

      <div class="text-center mb-8">
        <h1 class="font-bungee text-3xl text-text-primary uppercase mb-2">Iniciar sesión</h1>
        <p class="text-text-muted">Accede a tu cuenta para comentar y opinar</p>
      </div>

      <div class="bg-dark-secondary rounded-2xl border border-white/5 p-8">

        <div id="error-general" class="hidden mb-6 bg-red-500/10 border border-red-500/20 text-red-400 rounded-lg px-4 py-3 text-sm"></div>

        <form id="form-login" novalidate>

          <!-- Identifier -->
          <div class="mb-5">
            <label for="identifier" class="block text-sm font-medium text-text-secondary mb-2">
              Email o nombre de usuario
            </label>
            <input
              type="text"
              id="identifier"
              name="identifier"
              autocomplete="username"
              placeholder="tu@email.com"
              class="w-full bg-dark-primary border border-dark-tertiary text-text-primary placeholder-text-muted rounded-lg px-4 py-3 focus:outline-none focus:border-primary transition"
            />
            <p id="error-identifier" class="hidden mt-1.5 text-xs text-red-400"></p>
          </div>

          <!-- Password -->
          <div class="mb-6">
            <label for="password" class="block text-sm font-medium text-text-secondary mb-2">
              Contraseña
            </label>
            <div class="relative">
              <input
                type="password"
                id="password"
                name="password"
                autocomplete="current-password"
                placeholder="••••••••"
                class="w-full bg-dark-primary border border-dark-tertiary text-text-primary placeholder-text-muted rounded-lg px-4 py-3 pr-12 focus:outline-none focus:border-primary transition"
              />
              <button
                type="button"
                id="toggle-password"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-text-secondary transition"
                aria-label="Mostrar contraseña"
              >
                <svg id="eye-show" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                <svg id="eye-hide" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                </svg>
              </button>
            </div>
            <p id="error-password" class="hidden mt-1.5 text-xs text-red-400"></p>
          </div>

          <button
            type="submit"
            id="btn-submit"
            class="w-full bg-primary hover:bg-primary/90 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold rounded-lg px-6 py-3 transition flex items-center justify-center gap-2"
          >
            <span id="btn-text">Iniciar sesión</span>
            <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 12H4z"></path>
            </svg>
          </button>
        </form>

        <p class="text-center text-text-muted text-sm mt-6">
          ¿No tienes cuenta?
          <a href="/registro" class="text-primary hover:text-primary/80 font-medium transition ml-1">Regístrate</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const API_URL = '/api';

  if (localStorage.getItem('pixelcrit_token')) {
    window.location.href = '/';
  }

  const form = document.getElementById('form-login') as HTMLFormElement | null;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text') as HTMLElement | null;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement | null;
  const errorGeneral = document.getElementById('error-general') as HTMLElement | null;

  const toggleBtn = document.getElementById('toggle-password') as HTMLButtonElement | null;
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const eyeShow = document.getElementById('eye-show') as HTMLElement | null;
  const eyeHide = document.getElementById('eye-hide') as HTMLElement | null;

  toggleBtn?.addEventListener('click', () => {
    if (!passwordInput) return;
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeShow?.classList.toggle('hidden', !isPassword);
    eyeHide?.classList.toggle('hidden', isPassword);
    toggleBtn.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
  });

  function showFieldError(fieldId: string, msg: string) {
    const el = document.getElementById(fieldId);
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function clearErrors() {
    ['error-identifier', 'error-password'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.textContent = ''; el.classList.add('hidden'); }
    });
    if (errorGeneral) {
      errorGeneral.textContent = '';
      errorGeneral.classList.add('hidden');
    }
  }

  function setLoading(loading: boolean) {
    if (btnSubmit) btnSubmit.disabled = loading;
    if (btnText) btnText.textContent = loading ? 'Iniciando sesión...' : 'Iniciar sesión';
    btnSpinner?.classList.toggle('hidden', !loading);
  }

  function validate(identifier: string, password: string) {
    let ok = true;
    if (!identifier.trim()) {
      showFieldError('error-identifier', 'Este campo es obligatorio.');
      ok = false;
    }
    if (!password) {
      showFieldError('error-password', 'La contraseña es obligatoria.');
      ok = false;
    } else if (password.length < 8) {
      showFieldError('error-password', 'La contraseña debe tener al menos 8 caracteres.');
      ok = false;
    }
    return ok;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const identifier = (document.getElementById('identifier') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;

    if (!validate(identifier, password)) return;

    setLoading(true);
    try {
      const res = await fetch(`${API_URL}/auth/local`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ identifier, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        const msg = data?.error?.message ?? 'Credenciales incorrectas. Inténtalo de nuevo.';
        if (errorGeneral) {
          errorGeneral.textContent = msg;
          errorGeneral.classList.remove('hidden');
        }
        return;
      }

      const { jwt, user } = data;
      localStorage.setItem('pixelcrit_token', jwt);
      localStorage.setItem('pixelcrit_user', JSON.stringify({
        id: user.id,
        username: user.username,
        email: user.email,
      }));
      window.location.href = '/';
    } catch (err) {
      if (errorGeneral) {
        errorGeneral.textContent = 'Error de conexión. Comprueba tu red e inténtalo de nuevo.';
        errorGeneral.classList.remove('hidden');
      }
    } finally {
      setLoading(false);
    }
  });
</script>
