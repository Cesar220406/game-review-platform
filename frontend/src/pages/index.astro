---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/home/HeroSection.astro";
import FeaturedGames from "../components/home/FeaturedGames.astro";
import GenreGrid from "../components/home/GenreGrid.astro";
import PlatformBanner from "../components/home/PlatformBanner.astro";
import { getVideojuegosDestacados, getGeneros, getHome, getPlatforms } from "../lib/api.js";

const [destacados, generos, home, plataformas] = await Promise.all([
  getVideojuegosDestacados(),
  getGeneros(),
  getHome(),
  getPlatforms()
]);

const {
  heroEtiqueta,
  heroTitulo,
  heroTituloDestacado,
  heroDescripcion,
  heroBotonPrincipal,
  heroBotonSecundario,
  heroImagen,
  seccionDestacadosTitulo,
  seccionDestacadosSubtitulo,
  seccionGenerosTitulo,
  plataformas_titulo,
  plataformas_subtitulo,
  plataformas_cta,
  metaTitle,
  metaDescription
} = home;

const heroImagenUrl = heroImagen?.url ?? '/img/imagenhero.webp';
---

<Layout title={metaTitle} description={metaDescription}>
  <link slot="head" rel="preload" as="image" href={heroImagenUrl} fetchpriority="high" />
  <HeroSection
    etiqueta={heroEtiqueta}
    titulo={heroTitulo}
    tituloDestacado={heroTituloDestacado}
    descripcion={heroDescripcion}
    botonPrincipal={heroBotonPrincipal}
    botonSecundario={heroBotonSecundario}
    imagenUrl={heroImagenUrl}
  />
  <FeaturedGames
    titulo={seccionDestacadosTitulo}
    subtitulo={seccionDestacadosSubtitulo}
    games={destacados}
  />
  <PlatformBanner
    titulo={plataformas_titulo}
    subtitulo={plataformas_subtitulo}
    cta={plataformas_cta}
    plataformas={plataformas}
  />
  <GenreGrid
    titulo={seccionGenerosTitulo}
    generos={generos}
  />
</Layout>