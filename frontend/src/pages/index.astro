---
import Layout from "../layouts/Layout.astro";
import { getVideojuegosDestacados } from "../lib/api.js";

const destacados = await getVideojuegosDestacados();
---

<Layout title="Game Review - Home">
  <section class="relative overflow-hidden">
    <!-- Imagen de fondo -->
    <div class="absolute inset-0">
      <img
        src="/img/imagenhero.webp"
        alt=""
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-linear-to-r from-dark-primary via-dark-primary/90 to-dark-primary/40"></div>
    </div>

    <!-- Contenido -->
    <div class="relative max-w-7xl mx-auto px-4 py-24 md:py-36 lg:py-44">
      <div class="max-w-2xl flex flex-col gap-6">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 bg-primary/15 text-primary border border-primary/30 rounded-full px-4 py-1.5 text-sm font-medium w-fit">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Nueva temporada de reseñas
        </span>

        <h1 class="font-bungee text-4xl md:text-5xl lg:text-6xl text-text-primary uppercase leading-tight">
          Reseñas críticas
          <span class="text-secondary">sin filtro</span>
        </h1>

        <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-lg">
          Críticas honestas, puntuaciones detalladas y análisis sin relleno.
          Solo lo que importa para decidir tu próxima partida.
        </p>

        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href="/videojuegos"
            class="inline-flex items-center gap-2 bg-secondary hover:bg-secondary/85 text-white font-bold px-7 py-3.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-secondary/25 hover:-translate-y-0.5"
          >
            Ver todas las reseñas
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="/generos"
            class="inline-flex items-center gap-2 border border-text-muted/40 text-text-secondary hover:text-text-primary hover:border-text-secondary px-7 py-3.5 rounded-lg transition-all duration-200"
          >
            Explorar géneros
          </a>
        </div>

        <!-- Stats rápidas -->
        <div class="flex gap-8 pt-6 border-t border-dark-tertiary/60 mt-2">
          <div>
            <span class="font-bungee text-2xl text-accent">150+</span>
            <p class="text-text-muted text-sm">Reseñas</p>
          </div>
          <div>
            <span class="font-bungee text-2xl text-accent">20+</span>
            <p class="text-text-muted text-sm">Géneros</p>
          </div>
          <div>
            <span class="font-bungee text-2xl text-accent">100%</span>
            <p class="text-text-muted text-sm">Honestidad</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-16">
    <!-- Encabezado de sección -->
    <div class="flex items-center justify-between mb-10">
      <div>
        <h2 class="font-bungee text-3xl md:text-4xl text-text-primary uppercase">Reseñas destacadas</h2>
        <p class="text-text-muted mt-2">Los juegos que están dando de qué hablar</p>
      </div>
      <a href="/videojuegos" class="hidden md:inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium transition">
        Ver todas
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {destacados.map((v: any) => (
        <a href={`/videojuegos/${v.slug}`} class="group bg-dark-secondary rounded-xl overflow-hidden border border-dark-tertiary/50 hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/10">
          <!-- Imagen -->
          <div class="relative aspect-video overflow-hidden">
            {v.imagen ? (
              <img
                src={v.imagen}
                alt={v.titulo}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full bg-dark-tertiary flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-text-muted/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </div>
            )}
            {/* Badge de puntuación */}
            {v.puntuacion != null && (
              <div class={`absolute top-3 right-3 font-bungee text-sm px-3 py-1 rounded-lg backdrop-blur-sm ${
                v.puntuacion >= 8 ? 'bg-green-500/90 text-white' :
                v.puntuacion >= 5 ? 'bg-accent/90 text-dark-primary' :
                'bg-red-500/90 text-white'
              }`}>
                {v.puntuacion.toFixed(1)}
              </div>
            )}
          </div>

          <!-- Contenido -->
          <div class="p-5">
            {/* Géneros */}
            {v.generos.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-3">
                {v.generos.slice(0, 3).map((g: string) => (
                  <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded-full">{g}</span>
                ))}
              </div>
            )}

            <h3 class="font-bungee text-lg text-text-primary group-hover:text-primary transition-colors uppercase leading-tight">
              {v.titulo}
            </h3>

            {v.descripcionCorta && (
              <p class="text-text-muted text-sm mt-2 line-clamp-2">{v.descripcionCorta}</p>
            )}

            <div class="flex items-center gap-2 mt-4 text-sm text-primary font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              Leer reseña
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Link móvil -->
    <div class="mt-8 text-center md:hidden">
      <a href="/videojuegos" class="inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium transition">
        Ver todas las reseñas
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>