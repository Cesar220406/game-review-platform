---
interface Props {
  titulo: string;
  slug: string;
  imagen?: string;
  puntuacion?: number;
  generos: { nombre: string; slug: string }[];
  descripcionCorta?: string;
}

const { titulo, slug, imagen, puntuacion, generos, descripcionCorta } = Astro.props;
---

<a href={`/videojuegos/${slug}`} class="group bg-dark-secondary rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/40 flex flex-col">
  
  <div class="relative aspect-video overflow-hidden">
    {imagen ? (
      <img src={imagen} alt={titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full bg-dark-primary flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
        </svg>
      </div>
    )}
    {puntuacion != null && (
      <div class="absolute top-3 right-3 bg-dark-primary/80 backdrop-blur-sm border border-white/10 rounded-lg px-2.5 py-1 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-secondary" viewBox="0 0 20 20" fill="currentColor">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-sm font-bold text-text-primary">{puntuacion}<span class="text-text-muted font-normal">/100</span></span>
      </div>
    )}
  </div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    {generos.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {generos.slice(0, 3).map((g) => (
          <span class="text-xs bg-primary/10 text-primary border border-primary/20 rounded-full px-2.5 py-0.5">{g.nombre}</span>
        ))}
      </div>
    )}
    <h3 class="font-bungee text-lg text-text-primary uppercase group-hover:text-primary transition-colors leading-tight">
      {titulo}
    </h3>
    {descripcionCorta && (
      <p class="text-sm text-text-muted leading-relaxed line-clamp-2 flex-1">{descripcionCorta}</p>
    )}
    <span class="inline-flex items-center gap-1.5 text-sm text-primary font-medium mt-auto pt-1">
      Leer reseña
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </span>
  </div>
</a>