---
interface Props {
  entidadTipo: 'videojuego' | 'articulo';
  entidadId: number;
}
const { entidadTipo, entidadId } = Astro.props;
---

<section
  id="sc-root"
  class="mt-12 pt-10 border-t border-white/5"
  data-entidad-tipo={entidadTipo}
  data-entidad-id={String(entidadId)}
>
  <h2 class="font-bungee text-2xl text-text-primary uppercase mb-6 flex items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    Comentarios
  </h2>

  <!-- Loading -->
  <div id="sc-loading" class="flex items-center gap-3 text-text-muted py-8">
    <svg class="w-5 h-5 animate-spin text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 12H4z"></path>
    </svg>
    Cargando comentarios…
  </div>

  <!-- Error global de carga -->
  <div id="sc-error-carga" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 rounded-lg px-4 py-3 text-sm mb-6"></div>

  <!-- Lista de comentarios -->
  <div id="sc-lista" class="hidden flex flex-col gap-6 mb-8"></div>

  <!-- Sin comentarios -->
  <div id="sc-vacio" class="hidden text-center py-10 text-text-muted">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    Sé el primero en comentar.
  </div>

  <!-- Formulario nuevo comentario -->
  <div id="sc-form-area" class="hidden">
    <div class="bg-dark-secondary rounded-xl border border-white/5 p-6">
      <h3 class="text-text-primary font-semibold mb-4">Deja tu comentario</h3>

      <!-- Estado guest -->
      <div id="sc-guest" class="hidden text-center py-4">
        <p class="text-text-muted mb-3">¿Quieres participar en la conversación?</p>
        <a
          href="/login"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold rounded-lg px-5 py-2.5 transition text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          Inicia sesión para comentar
        </a>
      </div>

      <!-- Formulario auth -->
      <div id="sc-form-auth" class="hidden">
        <div id="sc-error-post" class="hidden mb-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-lg px-4 py-3 text-sm"></div>
        <textarea
          id="sc-textarea"
          rows="4"
          placeholder="Comparte tu opinión…"
          class="w-full bg-dark-primary border border-dark-tertiary text-text-primary placeholder-text-muted rounded-lg px-4 py-3 focus:outline-none focus:border-primary transition resize-none text-sm"
        ></textarea>
        <div class="flex justify-end mt-3">
          <button
            id="sc-btn-comentar"
            class="flex items-center gap-2 bg-primary hover:bg-primary/90 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold rounded-lg px-5 py-2.5 transition text-sm"
          >
            <span id="sc-btn-text">Publicar comentario</span>
            <svg id="sc-btn-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 12H4z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const API_URL = '/api';

  const root = document.getElementById('sc-root');
  if (!root) throw new Error('SeccionComentarios: root element not found');

  const { entidadTipo, entidadId } = root.dataset;

  const elLoading = document.getElementById('sc-loading');
  const elErrorCarga = document.getElementById('sc-error-carga');
  const elLista = document.getElementById('sc-lista');
  const elVacio = document.getElementById('sc-vacio');
  const elFormArea = document.getElementById('sc-form-area');
  const elGuest = document.getElementById('sc-guest');
  const elFormAuth = document.getElementById('sc-form-auth');
  const elErrorPost = document.getElementById('sc-error-post');
  const scTextarea = document.getElementById('sc-textarea');
  const scBtnComentar = document.getElementById('sc-btn-comentar');
  const scBtnText = document.getElementById('sc-btn-text');
  const scBtnSpinner = document.getElementById('sc-btn-spinner');

  const token = localStorage.getItem('pixelcrit_token');
  const userRaw = localStorage.getItem('pixelcrit_user');
  const user = userRaw ? JSON.parse(userRaw) : null;

  // ── Helpers ─────────────────────────────────────────────────────────────

  function esc(str) {
    return String(str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatDate(dateStr) {
    return new Date(dateStr).toLocaleDateString('es-ES', {
      year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  function tiempoLectura(texto) {
    if (!texto || texto.length <= 200) return null;
    const palabras = texto.trim().split(/\s+/).length;
    return Math.ceil(palabras / 200);
  }

  function renderAvatar(username) {
    const inicial = (username?.[0] ?? '?').toUpperCase();
    return `<div class="w-9 h-9 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center text-primary font-bold text-sm flex-shrink-0">${esc(inicial)}</div>`;
  }

  function renderTiempoLectura(texto) {
    const tr = tiempoLectura(texto);
    if (!tr) return '';
    return `
      <span class="inline-flex items-center gap-1 text-xs text-text-muted mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        ${tr} min de lectura
      </span>`;
  }

  function renderRespuesta(r) {
    const username = r.autor?.username ?? 'Anónimo';
    return `
      <div class="flex gap-3 mt-4 pl-4 border-l-2 border-primary/20" data-respuesta-id="${r.id}">
        ${renderAvatar(username)}
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <span class="text-sm font-semibold text-text-primary">${esc(username)}</span>
            <span class="text-xs text-text-muted">${formatDate(r.createdAt)}</span>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed whitespace-pre-wrap">${esc(r.contenido)}</p>
          ${renderTiempoLectura(r.contenido)}
        </div>
      </div>`;
  }

  function renderReplyForm(comentarioId) {
    if (!user) return '';
    return `
      <div id="reply-form-${comentarioId}" class="hidden mt-3 pl-4 border-l-2 border-primary/20">
        <div id="reply-error-${comentarioId}" class="hidden mb-2 bg-red-500/10 border border-red-500/20 text-red-400 rounded-lg px-3 py-2 text-xs"></div>
        <textarea
          id="reply-text-${comentarioId}"
          rows="3"
          placeholder="Escribe tu respuesta…"
          class="w-full bg-dark-primary border border-dark-tertiary text-text-primary placeholder-text-muted rounded-lg px-3 py-2 focus:outline-none focus:border-primary transition resize-none text-sm"
        ></textarea>
        <div class="flex items-center justify-end gap-2 mt-2">
          <button
            class="sc-btn-cancelar-reply text-xs text-text-muted hover:text-text-secondary transition px-3 py-1.5"
            data-id="${comentarioId}"
          >Cancelar</button>
          <button
            class="sc-btn-enviar-reply flex items-center gap-1.5 bg-primary hover:bg-primary/90 disabled:opacity-60 text-white text-xs font-semibold rounded-lg px-4 py-1.5 transition"
            data-id="${comentarioId}"
          >
            <span class="reply-btn-text">Responder</span>
            <svg class="reply-btn-spinner hidden w-3.5 h-3.5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 12H4z"></path>
            </svg>
          </button>
        </div>
      </div>`;
  }

  function renderComentario(c) {
    const username = c.autor?.username ?? 'Anónimo';
    const respuestasHtml = (c.respuestas ?? []).map(renderRespuesta).join('');
    const replyBtn = user
      ? `<button class="sc-btn-responder inline-flex items-center gap-1 text-xs text-text-muted hover:text-primary transition mt-2" data-id="${c.id}">
           <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
           </svg>
           Responder
         </button>`
      : '';

    return `
      <div class="bg-dark-secondary rounded-xl border border-white/5 p-5" data-comentario-id="${c.id}">
        <div class="flex gap-3">
          ${renderAvatar(username)}
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="font-semibold text-text-primary text-sm">${esc(username)}</span>
              <span class="text-xs text-text-muted">${formatDate(c.createdAt)}</span>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed whitespace-pre-wrap">${esc(c.contenido)}</p>
            ${renderTiempoLectura(c.contenido)}
            ${replyBtn}
            ${renderReplyForm(c.id)}
          </div>
        </div>
        <div id="respuestas-${c.id}" class="mt-1">
          ${respuestasHtml}
        </div>
      </div>`;
  }

  // ── Fetch comentarios ────────────────────────────────────────────────────

  async function cargarComentarios() {
    elLoading?.classList.remove('hidden');
    elLista?.classList.add('hidden');
    elVacio?.classList.add('hidden');
    elFormArea?.classList.add('hidden');

    try {
      const url = `${API_URL}/comentarios`
        + `?filters[${entidadTipo}][id][$eq]=${entidadId}`
        + `&populate[autor]=true`
        + `&populate[respuestas][populate][autor]=true`
        + `&sort=createdAt:asc`;

      const res = await fetch(url);
      if (!res.ok) throw new Error(`Error ${res.status}`);
      const { data } = await res.json();

      elLoading?.classList.add('hidden');

      if (!data || data.length === 0) {
        elVacio?.classList.remove('hidden');
      } else {
        elLista.innerHTML = data.map(renderComentario).join('');
        elLista?.classList.remove('hidden');
        // Re-add flex class after setting innerHTML
        elLista?.classList.add('flex', 'flex-col', 'gap-6');
      }

      // Mostrar formulario siempre
      elFormArea?.classList.remove('hidden');
      if (user && token) {
        elFormAuth?.classList.remove('hidden');
        elGuest?.classList.add('hidden');
      } else {
        elGuest?.classList.remove('hidden');
        elFormAuth?.classList.add('hidden');
      }
    } catch (err) {
      elLoading?.classList.add('hidden');
      elErrorCarga.textContent = `No se pudieron cargar los comentarios: ${err.message}`;
      elErrorCarga?.classList.remove('hidden');
      // Mostrar formulario igualmente
      elFormArea?.classList.remove('hidden');
      if (user && token) {
        elFormAuth?.classList.remove('hidden');
      } else {
        elGuest?.classList.remove('hidden');
      }
    }
  }

  // ── POST comentario ──────────────────────────────────────────────────────

  async function postComentario() {
    const contenido = scTextarea.value.trim();
    if (!contenido) return;

    scBtnComentar.disabled = true;
    scBtnText.textContent = 'Publicando…';
    scBtnSpinner?.classList.remove('hidden');
    elErrorPost?.classList.add('hidden');

    try {
      // Los IDs de relación van como query params (_vj / _art) para evitar
      // la validación del body de Strapi v5 que rechaza relaciones del cliente.
      const qp = entidadTipo === 'videojuego' ? `_vj=${entidadId}` : `_art=${entidadId}`;

      const res = await fetch(`${API_URL}/comentarios?${qp}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ data: { contenido } }),
      });

      if (!res.ok) {
        const errData = await res.json();
        throw new Error(errData?.error?.message ?? `Error ${res.status}`);
      }

      const { data: nuevo } = await res.json();
      // Add populated autor
      nuevo.autor = user;
      nuevo.respuestas = [];

      // Remove empty state and show list
      elVacio?.classList.add('hidden');
      if (elLista?.classList.contains('hidden')) {
        elLista?.classList.remove('hidden');
        elLista?.classList.add('flex', 'flex-col', 'gap-6');
      }

      elLista.insertAdjacentHTML('beforeend', renderComentario(nuevo));
      scTextarea.value = '';
    } catch (err) {
      elErrorPost.textContent = `Error al publicar: ${err.message}`;
      elErrorPost?.classList.remove('hidden');
    } finally {
      scBtnComentar.disabled = false;
      scBtnText.textContent = 'Publicar comentario';
      scBtnSpinner?.classList.add('hidden');
    }
  }

  // ── POST respuesta ───────────────────────────────────────────────────────

  async function postRespuesta(comentarioId) {
    const textarea = document.getElementById(`reply-text-${comentarioId}`);
    const errEl = document.getElementById(`reply-error-${comentarioId}`);
    const btn = elLista.querySelector(`.sc-btn-enviar-reply[data-id="${comentarioId}"]`);
    const btnTextEl = btn?.querySelector('.reply-btn-text');
    const btnSpinnerEl = btn?.querySelector('.reply-btn-spinner');

    const contenido = textarea?.value.trim();
    if (!contenido) return;

    if (btn) btn.disabled = true;
    if (btnTextEl) btnTextEl.textContent = 'Enviando…';
    btnSpinnerEl?.classList.remove('hidden');
    errEl?.classList.add('hidden');

    try {
      const res = await fetch(`${API_URL}/respuestas`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({
          data: {
            contenido,
            comentario: comentarioId,
          },
        }),
      });

      if (!res.ok) {
        const errData = await res.json();
        throw new Error(errData?.error?.message ?? `Error ${res.status}`);
      }

      const { data: nueva } = await res.json();
      nueva.autor = user;

      const respuestasContainer = document.getElementById(`respuestas-${comentarioId}`);
      respuestasContainer?.insertAdjacentHTML('beforeend', renderRespuesta(nueva));

      // Hide form
      const replyForm = document.getElementById(`reply-form-${comentarioId}`);
      replyForm?.classList.add('hidden');
      if (textarea) textarea.value = '';
    } catch (err) {
      if (errEl) {
        errEl.textContent = `Error al responder: ${err.message}`;
        errEl.classList.remove('hidden');
      }
    } finally {
      if (btn) btn.disabled = false;
      if (btnTextEl) btnTextEl.textContent = 'Responder';
      btnSpinnerEl?.classList.add('hidden');
    }
  }

  // ── Event delegation ─────────────────────────────────────────────────────

  elLista?.addEventListener('click', (e) => {
    const target = e.target.closest('button');
    if (!target) return;

    if (target.classList.contains('sc-btn-responder')) {
      const id = target.dataset.id;
      const form = document.getElementById(`reply-form-${id}`);
      form?.classList.toggle('hidden');
      if (!form?.classList.contains('hidden')) {
        document.getElementById(`reply-text-${id}`)?.focus();
      }
    }

    if (target.classList.contains('sc-btn-cancelar-reply')) {
      const id = target.dataset.id;
      const form = document.getElementById(`reply-form-${id}`);
      form?.classList.add('hidden');
    }

    if (target.classList.contains('sc-btn-enviar-reply')) {
      const id = target.dataset.id;
      postRespuesta(id);
    }
  });

  scBtnComentar?.addEventListener('click', postComentario);

  // ── Init ─────────────────────────────────────────────────────────────────

  cargarComentarios();
</script>
