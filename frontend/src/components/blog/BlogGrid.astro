---
import { calcularTiempoLectura } from "../../lib/utils.js";

interface Props {
  articulos: Array<{
    slug: string;
    titulo: string;
    extracto?: string;
    contenido?: string;
    fechaPublicacion: string;
    imagen?: string | null;
  }>;
  textoLeerArticulo: string;
  textoSinResultados: string;
  textoVerTodos: string;
}

const { articulos, textoLeerArticulo, textoSinResultados, textoVerTodos } = Astro.props;
---

{articulos.length > 0 ? (
  <div class="flex flex-col gap-8">
    {articulos.map((articulo) => (
      <a href={`/blog/${articulo.slug}`} class="block group">
        <article class="grid md:grid-cols-[280px_1fr] gap-0 bg-dark-secondary rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all duration-300">
          <div class="aspect-[16/10] md:aspect-auto overflow-hidden">
            {articulo.imagen ? (
              <img src={articulo.imagen} alt={articulo.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            ) : (
              <div class="w-full h-full min-h-[180px] bg-dark-tertiary flex items-center justify-center">
                <span class="text-text-muted text-sm">Sin imagen</span>
              </div>
            )}
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center">
            <time class="text-text-muted text-xs mb-1" datetime={articulo.fechaPublicacion}>
              {new Date(articulo.fechaPublicacion).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="text-xs text-text-muted flex items-center gap-1 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
              </svg>
              {calcularTiempoLectura(articulo.contenido)} min de lectura
            </p>
            <h2 class="font-bungee text-lg md:text-xl text-text-primary uppercase leading-tight mb-3 group-hover:text-primary transition-colors duration-300">
              {articulo.titulo}
            </h2>
            <p class="text-text-secondary text-sm leading-relaxed line-clamp-2 mb-4">{articulo.extracto}</p>
            <span class="text-primary text-sm font-medium inline-flex items-center gap-2 group-hover:gap-3 transition-all duration-300">
              {textoLeerArticulo}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </article>
      </a>
    ))}
  </div>
) : (
  <div class="text-center py-20">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-dark-secondary border border-white/10 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
    </div>
    <p class="text-text-muted text-lg">{textoSinResultados}</p>
    <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium mt-4 transition">
      {textoVerTodos}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </a>
  </div>
)}
