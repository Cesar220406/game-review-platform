---
import GameCard from "../shared/GameCard.astro";

interface Genero {
  nombre: string;
  slug: string;
}

interface Videojuego {
  id: number;
  titulo: string;
  slug: string;
  descripcionCorta?: string;
  puntuacion?: number;
  imagen?: string;
  generos: Genero[];
}

interface Props {
  videojuegos: Videojuego[];
  textoSinResultados: string;
  textoVerTodos: string;
}

const { videojuegos, textoSinResultados, textoVerTodos } = Astro.props;
---

<!-- Grid de videojuegos -->
{videojuegos.length > 0 ? (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {videojuegos.map(({ titulo, slug, imagen, puntuacion, generos, descripcionCorta }) => (
      <GameCard
        titulo={titulo}
        slug={slug}
        imagen={imagen}
        puntuacion={puntuacion}
        generos={generos}
        descripcionCorta={descripcionCorta}
      />
    ))}
  </div>
) : (
  <div class="text-center py-20">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-dark-secondary border border-white/10 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
    </div>
    <p class="text-text-muted text-lg">{textoSinResultados}</p>
    <a href="/videojuegos" class="inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium mt-4 transition">
      {textoVerTodos}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </a>
  </div>
)}
