---
interface Props {
  titulo: string;
  descripcion: string;
  placeholderBusqueda: string;
  busquedaParam: string;
  totalResultados: number;
  filtroActivo: string | null;
  generoParam: string | null;
}

const { titulo, descripcion, placeholderBusqueda, busquedaParam, totalResultados, filtroActivo, generoParam } = Astro.props;

const textoDescripcion = (busquedaParam || filtroActivo)
  ? `${totalResultados} ${totalResultados === 1 ? 'resultado' : 'resultados'} encontrados.`
  : descripcion;
---

<!-- Cabecera -->
<div class="mb-8">
  <h1 class="font-bungee text-4xl md:text-5xl text-text-primary uppercase mb-3">{titulo}</h1>
  <p class="text-text-secondary text-lg">{textoDescripcion}</p>
</div>

<!-- Barra de búsqueda -->
<div class="mb-6">
  <div class="relative max-w-xl">
    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      id="busqueda-videojuegos"
      type="search"
      value={busquedaParam}
      placeholder={placeholderBusqueda}
      data-genero={generoParam ?? ""}
      class="w-full bg-dark-secondary border border-white/10 rounded-xl pl-11 pr-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-primary/60 transition-colors"
    />
    {busquedaParam && (
      <a
        href={generoParam ? `/videojuegos?genero=${generoParam}` : "/videojuegos"}
        class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-primary transition"
        aria-label="Limpiar búsqueda"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    )}
  </div>
</div>

<script>
  const input = document.getElementById('busqueda-videojuegos') as HTMLInputElement | null;
  if (input) {
    let timer: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        const q = input.value.trim();
        const genero = input.dataset.genero ?? '';
        const params = new URLSearchParams();
        if (genero) params.set('genero', genero);
        if (q) params.set('busqueda', q);
        const qs = params.toString();
        window.location.href = `/videojuegos${qs ? `?${qs}` : ''}`;
      }, 350);
    });
  }
</script>
