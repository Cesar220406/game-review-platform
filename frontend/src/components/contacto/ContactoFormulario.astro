---
interface Props {
  tituloFormulario: string;
  labelNombre: string;
  labelEmail: string;
  labelAsunto: string;
  labelMensaje: string;
  placeholderNombre: string;
  placeholderEmail: string;
  placeholderAsunto: string;
  placeholderMensaje: string;
  textoBotonEnviar: string;
}

const {
  tituloFormulario,
  labelNombre,
  labelEmail,
  labelAsunto,
  labelMensaje,
  placeholderNombre,
  placeholderEmail,
  placeholderAsunto,
  placeholderMensaje,
  textoBotonEnviar,
} = Astro.props;
---

<div class="bg-dark-secondary rounded-2xl border border-white/5 p-8 md:p-10 flex flex-col gap-6">
  {tituloFormulario && (
    <h2 class="font-bungee text-xl text-text-primary uppercase">{tituloFormulario}</h2>
  )}

  <form id="contact-form" class="flex flex-col gap-6" novalidate>

    <div class="grid sm:grid-cols-2 gap-6">
      <!-- Nombre -->
      <div class="flex flex-col gap-2">
        <label for="nombre" class="text-sm font-medium text-text-secondary">{labelNombre}</label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          placeholder={placeholderNombre}
          class="contact-input"
          autocomplete="name"
        />
        <span id="error-nombre" class="field-error hidden">El nombre es obligatorio.</span>
      </div>

      <!-- Email -->
      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm font-medium text-text-secondary">{labelEmail}</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder={placeholderEmail}
          class="contact-input"
          autocomplete="email"
        />
        <span id="error-email" class="field-error hidden">Introduce un email válido.</span>
      </div>
    </div>

    <!-- Asunto -->
    <div class="flex flex-col gap-2">
      <label for="asunto" class="text-sm font-medium text-text-secondary">{labelAsunto}</label>
      <select id="asunto" name="asunto" class="contact-input">
        <option value="" disabled selected>{placeholderAsunto}</option>
        <option value="consulta">Consulta general</option>
        <option value="colaboracion">Propuesta de colaboración</option>
        <option value="error">Error técnico</option>
        <option value="sugerencia">Sugerencia</option>
      </select>
      <span id="error-asunto" class="field-error hidden">Selecciona un asunto.</span>
    </div>

    <!-- Mensaje -->
    <div class="flex flex-col gap-2">
      <label for="mensaje" class="text-sm font-medium text-text-secondary">{labelMensaje}</label>
      <textarea
        id="mensaje"
        name="mensaje"
        rows="5"
        placeholder={placeholderMensaje}
        class="contact-input resize-none"
      ></textarea>
      <span id="error-mensaje" class="field-error hidden">El mensaje no puede estar vacío.</span>
    </div>

    <!-- Botón enviar -->
    <button
      type="submit"
      id="submit-btn"
      class="inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary/85 text-white font-bold px-7 py-3.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-secondary/25 hover:-translate-y-0.5 mt-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:translate-y-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
      </svg>
      {textoBotonEnviar}
    </button>

    <!-- Feedback -->
    <div id="success-msg" class="hidden text-center py-4 px-6 bg-green-500/10 border border-green-500/30 rounded-lg">
      <p class="text-green-400 font-medium">¡Mensaje enviado correctamente! Te responderemos pronto.</p>
    </div>
    <div id="error-msg" class="hidden text-center py-4 px-6 bg-red-500/10 border border-red-500/30 rounded-lg">
      <p class="text-red-400 font-medium">Ha ocurrido un error al enviar el mensaje. Inténtalo de nuevo.</p>
    </div>

  </form>
</div>

<style>
  .contact-input {
    background: var(--color-dark-primary);
    border: 1px solid color-mix(in srgb, white 8%, transparent);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    color: var(--color-text-primary);
    font-size: 0.9375rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  .contact-input::placeholder {
    color: var(--color-text-muted);
  }

  .contact-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .contact-input.input-error {
    border-color: rgb(239 68 68 / 0.6);
  }

  .field-error {
    font-size: 0.75rem;
    color: rgb(248 113 113);
  }
</style>

<script>
  const STRAPI_URL = "http://localhost:1337/api";
  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const successMsg = document.getElementById("success-msg");
  const errorMsg = document.getElementById("error-msg");

  function getField(id: string) {
    return document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
  }

  function getError(id: string) {
    return document.getElementById(`error-${id}`);
  }

  function setError(fieldId: string, show: boolean) {
    const field = getField(fieldId);
    const err = getError(fieldId);
    if (!field || !err) return;
    if (show) {
      field.classList.add("input-error");
      err.classList.remove("hidden");
    } else {
      field.classList.remove("input-error");
      err.classList.add("hidden");
    }
  }

  function validate(): boolean {
    const nombre = (getField("nombre") as HTMLInputElement)?.value.trim() ?? "";
    const email = (getField("email") as HTMLInputElement)?.value.trim() ?? "";
    const asunto = (getField("asunto") as HTMLSelectElement)?.value ?? "";
    const mensaje = (getField("mensaje") as HTMLTextAreaElement)?.value.trim() ?? "";

    const errors = {
      nombre: nombre.length === 0,
      email: !EMAIL_REGEX.test(email),
      asunto: asunto === "",
      mensaje: mensaje.length === 0,
    };

    Object.entries(errors).forEach(([id, hasError]) => setError(id, hasError));
    return !Object.values(errors).some(Boolean);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    successMsg?.classList.add("hidden");
    errorMsg?.classList.add("hidden");

    if (!validate()) return;

    const nombre = (getField("nombre") as HTMLInputElement).value.trim();
    const email = (getField("email") as HTMLInputElement).value.trim();
    const asunto = (getField("asunto") as HTMLSelectElement).value;
    const mensaje = (getField("mensaje") as HTMLTextAreaElement).value.trim();

    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch(`${STRAPI_URL}/contactos`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ data: { nombre, email, asunto, mensaje } }),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      form.reset();
      successMsg?.classList.remove("hidden");
      setTimeout(() => successMsg?.classList.add("hidden"), 6000);
    } catch {
      errorMsg?.classList.remove("hidden");
      setTimeout(() => errorMsg?.classList.add("hidden"), 6000);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  // Limpiar error al corregir campo
  ["nombre", "email", "asunto", "mensaje"].forEach((id) => {
    getField(id)?.addEventListener("input", () => setError(id, false));
  });
</script>
