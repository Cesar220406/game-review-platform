---
interface Props {
  titulo: string;
  descripcion: string;
}

const { titulo, descripcion } = Astro.props;
---

<div class="mb-12 text-center max-w-2xl mx-auto">
  <h1 class="font-bungee text-4xl md:text-5xl text-text-primary uppercase mb-3">{titulo}</h1>
  <p class="text-text-secondary text-lg">{descripcion}</p>
</div>
