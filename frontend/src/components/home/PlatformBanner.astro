---
interface Props {
  titulo: string;
  subtitulo: string;
  cta: string;
  plataformas: { nombre: string; slug: string }[];
}

const { titulo, subtitulo, cta, plataformas } = Astro.props;

const platformColors: Record<string, string> = {
  'ps5': '#0070D1',
  'ps4': '#2E6DB4',
  'xbox-series': '#107C10',
  'nintendo-switch': '#E60012',
  'pc': '#00ADEF',
  'steam-deck': '#66C0F4',
};

function getColor(slug: string) {
  return platformColors[slug] || '#8B5CF6';
}
---

<section class="bg-dark-secondary border-y border-white/5 py-12">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
      <div>
        <h2 class="font-bungee text-3xl md:text-4xl text-text-primary uppercase">{titulo}</h2>
        <p class="text-text-muted mt-2">{subtitulo}</p>
      </div>
      <a href="/plataformas" class="hidden md:inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium transition">
        {cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>

    <div class="flex flex-wrap gap-3">
      {plataformas.map(({ nombre, slug }) => {
        const color = getColor(slug);
        return (
          <a
            href={`/videojuegos?plataforma=${slug}`}
            class="platform-pill"
            style={`--c: ${color};`}
          >
            <span class="platform-dot" />
            <span>{nombre}</span>
          </a>
        );
      })}
    </div>

    <div class="mt-6 md:hidden">
      <a href="/plataformas" class="inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium transition">
        {cta}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .platform-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.125rem;
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 30%, transparent);
    border-radius: 9999px;
    color: var(--c);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .platform-pill:hover {
    background: var(--c);
    color: #fff;
    border-color: var(--c);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--c) 35%, transparent);
  }

  .platform-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c);
    flex-shrink: 0;
    transition: box-shadow 0.25s ease;
  }

  .platform-pill:hover .platform-dot {
    background: #fff;
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.5);
  }
</style>
