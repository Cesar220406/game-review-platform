---
interface Props {
  titulo: string;
  generos: { nombre: string; slug: string }[];
}

const { titulo, generos } = Astro.props;
---
<section class="max-w-7xl mx-auto px-4 py-16">
  <h2 class="font-bungee text-3xl md:text-4xl text-text-primary uppercase mb-8">{titulo}</h2>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
    {generos.map(({ nombre, slug }) => (
      <a
        href={`/videojuegos?genero=${slug}`}
        class="relative h-40 rounded-lg overflow-hidden group hover:scale-105 transition"
      >
        <img
          src={`/generos/${slug}.webp`}
          alt={nombre}
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-linear-to-t from-dark-primary/90 to-transparent flex items-end justify-center p-4">
          <h3 class="text-xl font-bold text-white">{nombre}</h3>
        </div>
      </a>
    ))}
  </div>
</section>